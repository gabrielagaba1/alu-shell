#!/usr/bin/env bash
# Init script to start, stop, or restart the manage_my_process script

PATH_TO_SCRIPT="$(dirname "$0")/manage_my_process"
PID_FILE="/var/run/my_process.pid"

case "$1" in
    start)
        $PATH_TO_SCRIPT &
        echo "$!" > "$PID_FILE"
        echo "manage_my_process started"
        ;;
    stop)
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")"
            rm -f "$PID_FILE"
        fi
        echo "manage_my_process stopped"
        ;;
    restart)
        if [ -f "$PID_FILE" ]; then
            kill "$(cat "$PID_FILE")"
            rm -f "$PID_FILE"
        fi
        $PATH_TO_SCRIPT &
        echo "$!" > "$PID_FILE"
        echo "manage_my_process restarted"
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        exit 1
        ;;
esac
